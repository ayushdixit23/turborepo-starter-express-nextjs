    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "compression": "^1.8.1",
